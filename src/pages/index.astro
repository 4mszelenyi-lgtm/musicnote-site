---
import "./index.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<link rel="shortcut icon" href="/logo.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Music.Notes</title>
	</head>
	<body>
		<main class="hero" aria-labelledby="home-title">
			<div class="brand-wrap">
				<section class="hero-copy">
					<header class="hero-header">
					<img src="/logo.png" alt="Music.Notes logo" class="logo" />
					<div class="brand-row">
						<h1 id="home-title" class="product">Music<span>.</span>Notes</h1>
						<p class="subtitle">Rehearsal and performance tool for gigging musicians</p>
						<div class="hero-actions">
							<a class="primary-button" href="https://musicnoteapp.com" target="_blank" rel="noopener noreferrer" aria-label="Open Music.Notes app in a new tab">Try the App</a>
							<a class="primary-button" href="/blog/" aria-label="Read the Music.Notes blog" style="margin-left: 16px;">Read the Blog</a>
							</div>
						</div>
					</header>
				</section>
			</div>
		</main>
		<section class="features-section" aria-labelledby="features-heading">
			<div class="features-wrap">
				<header class="features-header">
					<h2 id="features-heading">What is Music.Notes?</h2>
					<p class="features-intro">Music.Notes is a mobile-friendly webapp for capturing and displaying notes about the music you're learning and performing.</p>
				</header>
				<div class="features-grid">
					<div class="features-content">
						<h3 class="features-title">Key Features</h3>
						<ul class="features-list">
							<li>Capture chord progressions, lyrics, song form, and music notation</li>
							<li>Add drum patterns and live click</li>
							<li>Import existing pdf or jpg charts</li>
							<li>Organize everything in setlists</li>
							<li>Go Stage Mode for live performance</li>
						</ul>
					</div>
					<div class="features-images">
						<figure class="feature-image">
							<img src="/images/dashboard.png" alt="Application dashboard showing song list and interface" />
							<figcaption class="sr-only">Dashboard view of Music.Notes app</figcaption>
						</figure>
						<figure class="feature-image">
							<img src="/images/song-edit.png" alt="Editing a song in Music.Notes" />
							<figcaption class="sr-only">Song editing interface</figcaption>
						</figure>
						<figure class="feature-image">
							<img src="/images/insert-notation.png" alt="Insert notation feature" />
							<figcaption class="sr-only">Insert notation dialog</figcaption>
						</figure>
						<figure class="feature-image">
							<img src="/images/new-song-idea.png" alt="Creating a new song idea" />
							<figcaption class="sr-only">New song idea capture screen</figcaption>
						</figure>
					</div>
				</div>
			</div>
		</section>
	</body>
</html>
